MODULE 2: ROUTE OPTIMIZATION CORE (GRAPH ALGORITHMS)
🎯 Objective

To compute optimal delivery routes that:

Minimize distance / fuel / time
Ensure on-time delivery
Handle different road conditions
 convert the city into a graph:

Real World	Graph
Locations	Nodes
Roads	Edges
Distance/Time/Fuel	Edge Weights
📊 Graph Representation (C++)

Use Adjacency List (best for large graphs):

#include <bits/stdc++.h>
using namespace std;

// Adjacency list: node -> (neighbor, weight)
vector<pair<int,int>> adj[100];

// Dijkstra Algorithm
void dijkstra(int src, int n) {
    vector<int> dist(n, INT_MAX);

    // Min-heap (distance, node)
    priority_queue<pair<int,int>, vector<pair<int,int>>, greater<>> pq;

    dist[src] = 0;
    pq.push({0, src});

    while (!pq.empty()) {
        auto [d, u] = pq.top();
        pq.pop();

        for (auto [v, w] : adj[u]) {
            if (dist[v] > dist[u] + w) {
                dist[v] = dist[u] + w;
                pq.push({dist[v], v});
            }
        }
    }

    // Output
    cout << "Shortest distances from source:\n";
    for (int i = 0; i < n; i++) {
        cout << "To " << i << " = " << dist[i] << endl;
    }
}

// Main function
int main() {
    int n = 5; // number of locations

    // Graph edges (u -> v, weight)
    adj[0].push_back({1, 4});
    adj[0].push_back({2, 1});
    adj[2].push_back({1, 2});
    adj[1].push_back({3, 1});
    adj[2].push_back({3, 5});
    adj[3].push_back({4, 3});

    dijkstra(0, n);

    return 0;
}
