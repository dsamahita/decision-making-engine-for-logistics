MODULE 3: VEHICLE ASSIGNMENT (GREEDY ALGORITHMS)
🎯 Objective

Efficiently assign delivery requests to vehicles such that:

Maximum number of deliveries are completed
Vehicle capacity is not exceeded
High-value deliveries are prioritized
Decisions are made quickly (real-time)
🚚 Real-World Interpretation

You have:

Multiple vehicles (limited capacity)
Multiple packages (different weights, deadlines, priorities)

#include <bits/stdc++.h>
using namespace std;

struct Item {
    int value, weight;
};

// Compare by value/weight ratio
bool cmp(Item a, Item b) {
    return (double)a.value / a.weight > (double)b.value / b.weight;
}

double fractionalKnapsack(int W, vector<Item>& items) {
    // Step 1: sort by ratio
    sort(items.begin(), items.end(), cmp);

    double totalValue = 0.0;

    // Step 2: pick greedily
    for (auto item : items) {
        if (W >= item.weight) {
            totalValue += item.value;
            W -= item.weight;
        } else {
            totalValue += item.value * ((double)W / item.weight);
            break;
        }
    }
    return totalValue;
}

int main() {
    vector<Item> items = {
        {60, 10},
        {100, 20},
        {120, 30}
    };

    int capacity = 50;

    cout << "Maximum Value: " 
         << fractionalKnapsack(capacity, items);

    return 0;
}
