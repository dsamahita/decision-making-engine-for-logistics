MODULE 1: DELIVERY PRIORITIZATION ENGINE
Objective

To efficiently sort and prioritize delivery requests based on multiple parameters like:

Deadline
Customer priority
Distance
Weight

So that:

Urgent deliveries are handled first
High-value customers are prioritized
Overall system efficiency improves

Input Structure

Each delivery request contains:

struct Delivery {
    int id;
    int weight;
    int deadline;
    int priority;
    int distance;
};
 DESIGN APPROACH

We use three different sorting strategies, each solving a specific real-world need:

 1. Merge Sort (Deadline-Based Sorting)
 Purpose:

Sort deliveries by earliest deadline first

 Why Merge Sort?
Stable sorting → maintains fairness
Time complexity = O(n log n)
Good for large datasets
 Implementation:
void merge(vector<Delivery>& arr, int l, int m, int r) {
    int n1 = m - l + 1;
    int n2 = r - m;

    vector<Delivery> L(n1), R(n2);

    for (int i = 0; i < n1; i++) L[i] = arr[l + i];
    for (int j = 0; j < n2; j++) R[j] = arr[m + 1 + j];

    int i = 0, j = 0, k = l;

    while (i < n1 && j < n2) {
        if (L[i].deadline <= R[j].deadline) {
            arr[k++] = L[i++];
        } else {
            arr[k++] = R[j++];
        }
    }

    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];
}

void mergeSort(vector<Delivery>& arr, int l, int r) {
    if (l < r) {
        int m = (l + r) / 2;
        mergeSort(arr, l, m);
        mergeSort(arr, m + 1, r);
        merge(arr, l, m, r);
    }
}

2. Quick Sort (Priority-Based Ranking)
 Purpose:

Sort deliveries by highest customer priority first

🔧 Implementation:
int partition(vector<Delivery>& arr, int low, int high) {
    int pivot = arr[high].priority;
    int i = low - 1;

    for (int j = low; j < high; j++) {
        if (arr[j].priority > pivot) { // higher priority first
            i++;
            swap(arr[i], arr[j]);
        }
    }
    swap(arr[i + 1], arr[high]);
    return i + 1;
}

void quickSort(vector<Delivery>& arr, int low, int high) {
    if (low < high) {
        int pi = partition(arr, low, high);
        quickSort(arr, low, pi - 1);
        quickSort(arr, pi + 1, high);
    }
}


3. Heap (Priority Queue – Dynamic Scheduling)
 Purpose:

Handle real-time incoming deliveries

Implementation:
#include <queue>

struct Compare {
    bool operator()(Delivery a, Delivery b) {
        return a.priority < b.priority; // max heap
    }
};

priority_queue<Delivery, vector<Delivery>, Compare> pq;
Usage:
pq.push({1, 10, 5, 3, 20});
pq.push({2, 5, 2, 5, 15});

while (!pq.empty()) {
    Delivery d = pq.top();
    pq.pop();
    cout << d.id << " ";
}

“Heap is used for dynamic prioritization where new delivery requests arrive in real time.”

SAMPLE OUTPUT
After Merge Sort (by deadline):
ID 2 → Deadline 1
ID 1 → Deadline 3
ID 3 → Deadline 5

After Quick Sort (by priority):
ID 3 → Priority 5
ID 1 → Priority 3
ID 2 → Priority 1

